# Shopify Storefront API
# Create a Storefront API private app in Shopify Admin > Settings > Apps > Develop apps
# Permissions needed: unauthenticated_read_product_listings, unauthenticated_write_checkouts,
#                     unauthenticated_read_checkouts, unauthenticated_write_customers
SHOPIFY_STORE_DOMAIN=amy-tangerine.myshopify.com
SHOPIFY_STOREFRONT_TOKEN=your_storefront_access_token_here

# Vercel Analytics (auto-injected on Vercel, no action needed)
# NEXT_PUBLIC_VERCEL_ANALYTICS_ID=auto
